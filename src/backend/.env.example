FEATHERLESS_API_KEY=your_featherless_api_key_here
HUME_API_KEY=your_hume_api_key_here
EEG_SIMULATE=1
SPEAKER_MODEL=Dampfinchen/Llama-3.1-8B-Ultra-Instruct
PLANNER_API_KEY=your_google_ai_api_key_here
PLANNER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
PLANNER_MODEL=models/gemini-3.1-pro-preview
SUMMARIZER_MODEL=Qwen/Qwen2-72B-Instruct
WHITEBOARD_MODEL=Qwen/Qwen2-72B-Instruct
WHITEBOARD_ENABLED=0
WHITEBOARD_TIMEOUT_SECONDS=14
HUME_TTS_URL=https://api.hume.ai/v0/tts/file
