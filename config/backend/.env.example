# Featherless API (OpenAI-compatible) — https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
SPEAKER_MODEL=Dampfinchen/Llama-3.1-8B-Ultra-Instruct
PLANNER_API_KEY=your_google_ai_api_key_here
PLANNER_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
PLANNER_MODEL=models/gemini-3.1-pro-preview
SUMMARIZER_MODEL=Qwen/Qwen2-72B-Instruct
WHITEBOARD_MODEL=Qwen/Qwen2-72B-Instruct
WHITEBOARD_ENABLED=0
WHITEBOARD_TIMEOUT_SECONDS=14

# Hume TTS — https://hume.ai
HUME_API_KEY=your_hume_api_key_here
HUME_VOICE_NAME=KORA
HUME_TTS_URL=https://api.hume.ai/v0/tts/file

# Backend settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# EEG settings (custom-tuned calibration)
EEG_WINDOW_SECONDS=2.0
EEG_STRIDE_SECONDS=1.0
EEG_DWELL_WINDOWS=5
EEG_WATCHDOG_TIMEOUT=2.0
EEG_ARTIFACT_THRESHOLD_UV=100.0
EEG_BASELINE_SECONDS=10.0
EEG_EMA_ALPHA=0.2
EEG_CONFIDENCE_MIN=0.55

# VAD tuning
VAD_THRESHOLD=0.6
VAD_CONSECUTIVE=3

# Demo mode — set to 1 to simulate EEG without real Muse hardware
EEG_SIMULATE=1
