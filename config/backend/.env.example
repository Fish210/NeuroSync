# Featherless API (OpenAI-compatible)
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_SPEAKER_MODEL=meta-llama/Llama-3.1-8B-Instruct
FEATHERLESS_PLANNER_MODEL=meta-llama/Llama-3.1-70B-Instruct

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Backend settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# EEG settings
EEG_WINDOW_SECONDS=2.0
EEG_STRIDE_SECONDS=1.0
EEG_DWELL_WINDOWS=3
EEG_WATCHDOG_TIMEOUT=2.0
EEG_ARTIFACT_THRESHOLD_UV=100.0
EEG_BASELINE_SECONDS=10.0
